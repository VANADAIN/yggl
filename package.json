{
	"name": "yggl-monorepo",
	"private": true,
	"version": "0.0.0",
	"engines": {
		"node": ">=22.13",
		"pnpm": ">=11"
	},
	"scripts": {
		"build": "pnpm -r build",
		"test": "pnpm -r test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"tsup": "^8.4.0",
		"typescript": "^5.8.3",
		"vitest": "^3.1.4"
	}
}
